# ── EVM Configuration ──────────────────────────────────────────────
EVM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
EVM_VAULT_BRIDGE_ADDRESS=0xYOUR_DEPLOYED_VAULT_BRIDGE

# Private key of the relayer hot wallet (with RELAYER_ROLE on EVM contract)
RELAYER_EVM_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# ── Solana Configuration ────────────────────────────────────────────
# NOTE: Solana Devnet uses Chain ID 101 within AetherGate's internal
#       cross-chain identifier scheme. This is not a native Solana concept
#       but is enforced by both the EVM contract and this relayer to
#       distinguish Devnet (101) from Mainnet-Beta (102) bridge routes.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CHAIN_ID=101

# Base-58 encoded secret key of the relayer Solana wallet
RELAYER_SOLANA_PRIVATE_KEY=YOUR_BASE58_SOLANA_KEYPAIR

# Deployed Anchor program ID
SOLANA_PROGRAM_ID=AeTHrGATeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Relayer Settings ────────────────────────────────────────────────
# Poll interval in milliseconds for Solana event polling
SOLANA_POLL_INTERVAL_MS=4000
# Number of EVM blocks to wait before processing a Locked/Burned event
EVM_CONFIRMATIONS=2
# Maximum retries before a failed relay is queued for manual review
MAX_RETRIES=5
LOG_LEVEL=info
