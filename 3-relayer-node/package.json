{
  "name": "aethergate-relayer",
  "version": "1.0.0",
  "description": "AetherGate Layer-0 Cross-Chain Relayer — EVM ↔ Solana",
  "main": "dist/index.js",
  "scripts": {
    "build":   "tsc -p tsconfig.json",
    "start":   "node dist/index.js",
    "dev":     "ts-node -r dotenv/config src/index.ts",
    "lint":    "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor":     "^0.29.0",
    "@solana/web3.js":       "^1.91.0",
    "@solana/spl-token":     "^0.4.0",
    "bs58":                  "^5.0.0",
    "dotenv":                "^16.4.5",
    "ethers":                "^6.11.1",
    "pino":                  "^9.1.0",
    "pino-pretty":           "^11.0.0",
    "winston":               "^3.13.0"
  },
  "devDependencies": {
    "@types/bs58":   "^4.0.4",
    "@types/node":   "^20.12.0",
    "ts-node":       "^10.9.2",
    "typescript":    "^5.4.5"
  }
}
